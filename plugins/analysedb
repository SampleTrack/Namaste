import os
import time
import re
from pyrogram.types import InputMediaDocument, InlineKeyboardButton, InlineKeyboardMarkup
from utils import temp
from database.ia_filterdb import Media

@Client.on_message(filters.command("analyzedb") & filters.user(ADMINS))
async def analyze_database(client, message):
    msg = await message.reply("Analyzing database. This will take time and server resources. Please wait...")
    start_time = time.time()

    # 100 MB limit in bytes
    size_limit = 100 * 1024 * 1024 
    
    # Regex logic: Matches numbers from 100p to 399p, and 400p to 479p.
    # It will NOT match 480p, 720p, 1080p.
    res_pattern = re.compile(r'\b([1-3][0-9]{2}|4[0-7][0-9])p\b', re.IGNORECASE)

    # Reset cache for this run
    temp.INVALID_FILES = {'size': [], 'res': [], 'both': []}
    out_text = "Invalid Files Report:\n\n"

    # Use a direct MongoDB cursor to avoid Out-Of-Memory crashes
    cursor = Media.find({})

    async for doc in cursor:
        file_id = getattr(doc, 'file_id', None)
        file_name = getattr(doc, 'file_name', "")
        file_size = getattr(doc, 'file_size', 0)

        if not file_id:
            continue

        is_small = file_size < size_limit
        is_low_res = bool(res_pattern.search(file_name))

        if is_small and is_low_res:
            temp.INVALID_FILES['both'].append(file_id)
            out_text += f"[BOTH] {file_name} | Size: {file_size} bytes | ID: {file_id}\n"
        elif is_small:
            temp.INVALID_FILES['size'].append(file_id)
            out_text += f"[<100MB] {file_name} | Size: {file_size} bytes | ID: {file_id}\n"
        elif is_low_res:
            temp.INVALID_FILES['res'].append(file_id)
            out_text += f"[<480p] {file_name} | Size: {file_size} bytes | ID: {file_id}\n"

    end_time = time.time()
    elapsed = round(end_time - start_time, 2)

    count_size = len(temp.INVALID_FILES['size'])
    count_res = len(temp.INVALID_FILES['res'])
    count_both = len(temp.INVALID_FILES['both'])
    total_invalid = count_size + count_res + count_both

    if total_invalid == 0:
        return await msg.edit(f"Database analyzed in `{elapsed}s`. Zero invalid files found based on your criteria.")

    # Write report to text file
    file_path = "invalid_files_report.txt"
    with open(file_path, "w", encoding="utf-8") as f:
        f.write(f"Analysis completed in {elapsed} seconds.\n")
        f.write(f"Total Invalid Files Found: {total_invalid}\n")
        f.write("-" * 50 + "\n\n")
        f.write(out_text)

    # Generate Buttons
    buttons = [
        [InlineKeyboardButton(f"Delete < 100MB ({count_size})", callback_data="del_inv_size")],
        [InlineKeyboardButton(f"Delete < 480p ({count_res})", callback_data="del_inv_res")],
        [InlineKeyboardButton(f"Delete Both Limits ({count_both})", callback_data="del_inv_both")]
    ]

    await message.reply_document(
        document=file_path,
        caption=(
            f"**Database Analysis Complete**\n\n"
            f"⏱ **Time Taken:** `{elapsed} seconds`\n"
            f"🗑 **Total Invalid:** `{total_invalid}`\n\n"
            f"**WARNING:** Deletion is permanent. Review the text file before clicking."
        ),
        reply_markup=InlineKeyboardMarkup(buttons)
    )
    
    await msg.delete()
    os.remove(file_path)


@Client.on_callback_query(filters.regex(r'^del_inv_') & filters.user(ADMINS))
async def delete_invalid_files(client, query):
    action = query.data.split('_')[2]
    target_ids = temp.INVALID_FILES.get(action, [])

    if not target_ids:
        return await query.answer("No files found in memory to delete. Run /analyzedb again.", show_alert=True)

    # Remove buttons to prevent double-clicking
    await query.message.edit_reply_markup(reply_markup=None)
    status_msg = await query.message.reply(f"Deleting {len(target_ids)} files. Please wait, this might take a minute...")

    # Delete in chunks of 1000 to prevent MongoDB timeouts and lockups
    deleted_count = 0
    chunk_size = 1000
    
    for i in range(0, len(target_ids), chunk_size):
        chunk = target_ids[i:i + chunk_size]
        result = await Media.collection.delete_many({'_id': {'$in': chunk}})
        deleted_count += result.deleted_count

    # Clear memory for that specific category so it can't be triggered again
    temp.INVALID_FILES[action] = []

    await status_msg.edit(f"**Action Complete.**\nSuccessfully deleted `{deleted_count}` files from the database.")
